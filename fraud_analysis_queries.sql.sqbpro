<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="fraud_analysis.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2505"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Transactions" custom_title="0" dock_id="1" table="4,12:mainTransactions"/><dock_state state="000000ff00000000fd00000001000000020000015c00000266fc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000015c0000015c00ffffff0000015c0000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Transactions" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="40"/><column index="2" value="156"/><column index="3" value="163"/><column index="4" value="163"/><column index="5" value="163"/><column index="6" value="163"/><column index="7" value="163"/><column index="8" value="163"/><column index="9" value="171"/><column index="10" value="171"/><column index="11" value="171"/><column index="12" value="171"/><column index="13" value="171"/><column index="14" value="163"/><column index="15" value="163"/><column index="16" value="163"/><column index="17" value="163"/><column index="18" value="171"/><column index="19" value="171"/><column index="20" value="163"/><column index="21" value="171"/><column index="22" value="163"/><column index="23" value="171"/><column index="24" value="171"/><column index="25" value="171"/><column index="26" value="171"/><column index="27" value="163"/><column index="28" value="171"/><column index="29" value="171"/><column index="30" value="62"/><column index="31" value="47"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- Fraud Overview
SELECT 
    COUNT(*) AS total_transactions,
    SUM(Class) AS fraud_transactions,
    ROUND(SUM(Class) * 100.0 / COUNT(*), 4) AS fraud_percentage
FROM transactions;

-- Fraud Distribution
SELECT 
    Class,
    COUNT(*) AS number_of_transactions
FROM transactions
GROUP BY Class;

-- Fraud by Transaction Size
SELECT 
    CASE
        WHEN Amount &lt; 10 THEN 'Small'
        WHEN Amount BETWEEN 10 AND 100 THEN 'Medium'
        ELSE 'Large'
    END AS transaction_size,
    COUNT(*) AS total_transactions,
    SUM(Class) AS fraud_transactions
FROM transactions
GROUP BY transaction_size;

-- Fraud Probability by Transaction Size
SELECT 
    CASE
        WHEN Amount &lt; 10 THEN 'Small'
        WHEN Amount BETWEEN 10 AND 100 THEN 'Medium'
        ELSE 'Large'
    END AS transaction_size,
    COUNT(*) AS total_transactions,
    SUM(Class) AS fraud_transactions,
    ROUND((SUM(Class) * 1.0 / COUNT(*)) * 100, 4) AS fraud_percentage
FROM transactions
GROUP BY transaction_size
ORDER BY fraud_percentage DESC;

-- Fraud by Hour of Day
SELECT 
    CAST(Time/3600 AS INTEGER) AS hour_of_day,
    COUNT(*) AS total_transactions,
    SUM(Class) AS fraud_transactions
FROM transactions
GROUP BY hour_of_day
ORDER BY hour_of_day;</sql><current_tab id="0"/></tab_sql></sqlb_project>
